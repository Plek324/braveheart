# Ship Tracker Secrets
# Copy this file to secrets.env and fill in your values
# IMPORTANT: secrets.env is excluded from git (.gitignore)

# Your AISStream API key (get it from https://aisstream.io/apikeys)
AIS_API_KEY=your_api_key_here

# The MMSI number of the ship you want to track
# MMSI is a 9-digit number (e.g., 123456789)
MMSI_TO_TRACK=123456789